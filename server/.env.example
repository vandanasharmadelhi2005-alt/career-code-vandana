PORT=5000
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/careercoded_blog
# Railway MongoDB plugin may provide MONGO_URL or DATABASE_URL instead of MONGO_URI.
# The backend supports all three names.
JWT_SECRET=replace-with-a-long-random-production-secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
ADMIN_NAME=CareerCoded Admin
ADMIN_EMAIL=admin@careercoded.com
ADMIN_PASSWORD=change-this-before-deploy
